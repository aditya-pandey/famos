rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /contacts/{contactId} {
      allow create: if isValidContactSubmission();
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    function isValidContactSubmission() {
      return request.resource.data.keys().hasAll([
          'name',
          'email',
          'message',
          'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'name',
          'email',
          'message',
          'source',
          'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 160
        && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 2
        && request.resource.data.message.size() <= 5000
        && request.resource.data.createdAt is timestamp
        && (
          !('source' in request.resource.data)
          || request.resource.data.source == 'website-contact-form'
        );
    }
  }
}
